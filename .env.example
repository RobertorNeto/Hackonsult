# Pulso — variáveis de ambiente. Copie pra .env (local) ou cadastre no painel
# do Render (backend) / Vercel (frontend). .env real é gitignored.

# ───── Backend (Render) ─────
# Chave da OpenAI (chat/sugestões de meta).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# URLs públicas em produção. Em dev pode deixar em branco (usa localhost).
# PULSO_BACKEND_URL = a URL do próprio serviço no Render (monta o redirect OAuth).
# PULSO_FRONTEND_URL = a URL do front no Vercel (pra onde o callback volta).
PULSO_BACKEND_URL=https://pulso-api.onrender.com
PULSO_FRONTEND_URL=https://pulso.vercel.app

# Persistência opcional (Fly.io / disco montado). No Render free deixe em branco.
# PULSO_DATA_DIR=/data
# PULSO_AUTH_DB=/data/pulso_auth.db

# Cumbuca / Open Finance (defaults já apontam pra produção da Cumbuca).
# CUMBUCA_MCP_URL=https://mcp.cumbuca.com/mcp
# CUMBUCA_RESOURCE=https://mcp.cumbuca.com

# ───── Frontend (Vercel) ─────
# Base da API em produção. PRECISA do sufixo /api.
VITE_API_BASE=https://pulso-api.onrender.com/api
